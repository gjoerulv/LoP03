// Windows executable resources (M24) — configured from CMake; do not edit
// the generated copy. Icon + VERSIONINFO shown in Explorer/file properties.

#include <winver.h>

IDI_ICON1 ICON "@CRYSTAL_ICON_PATH@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEFLAGS 0x0L
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "ProductName", "Crystal Dungeons"
            VALUE "FileDescription", "Crystal Dungeons - 16-bit-inspired dungeon roguelite"
            VALUE "FileVersion", "@PROJECT_VERSION@"
            VALUE "ProductVersion", "@PROJECT_VERSION@"
            VALUE "OriginalFilename", "CrystalDungeons.exe"
            VALUE "InternalName", "CrystalDungeons"
            VALUE "LegalCopyright", "Original project content; see LICENSES.txt"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
